# ============================================================
# Student Analytics - 环境变量配置示例
# 使用说明：复制此文件为 .env 并根据实际情况修改配置
# ============================================================

# --------------------------------------------------------
# 端口配置
# --------------------------------------------------------
# MySQL 对外端口（默认 3307，避免与本地 MySQL 冲突）
MYSQL_PORT=3307

# MongoDB 对外端口
MONGO_PORT=27017

# 应用对外端口
APP_PORT=8090

# --------------------------------------------------------
# 数据库配置
# --------------------------------------------------------
# MySQL root 密码
MYSQL_ROOT_PASSWORD=root123

# 应用连接 MySQL 的用户名
DB_USERNAME=root

# 应用连接 MySQL 的密码
DB_PASSWORD=root123

# --------------------------------------------------------
# OpenAI 配置（可选，用于 AI 功能）
# --------------------------------------------------------
# 如果不需要 AI 功能，可以留空或使用占位符
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# --------------------------------------------------------
# 远程部署配置（用于 build-and-push.sh 脚本）
# --------------------------------------------------------
# 远程服务器 IP 地址或域名
REMOTE_SERVER=192.168.31.238

# 远程服务器登录用户名
REMOTE_USER=root

# 远程服务器登录密码
# ⚠️ 警告：请勿将包含真实密码的 .env 文件提交到版本控制系统
REMOTE_PASSWORD=your_password_here

# SSH 端口（默认 22）
REMOTE_PORT=22

# 远程服务器上的部署目录
REMOTE_DIR=/opt/student-analytics